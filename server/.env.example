# Copy to .env and fill in
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# MongoDB (same DB the .NET app used)
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/EshopDb
DB_NAME=EshopDb

# Auth
JWT_SECRET=super_secret_dev_key_change_me
JWT_EXPIRES=30d

# Seed admin (npm run seed)
ADMIN_EMAIL=admin@eshop.local
ADMIN_PASSWORD=Admin@123

# Email — bỏ trống = chỉ log ra console khi dev
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@eshop.local
CONTACT_TO=

# VietQR / Casso (payment)
VIETQR_BANK_BIN=970422
VIETQR_BANK_NAME=MBBank
VIETQR_ACCOUNT_NO=5835901072004
VIETQR_ACCOUNT_NAME=TRAN TAN LOC
VIETQR_TEMPLATE=compact2
CASSO_API_KEY=
CASSO_SECURE_TOKEN=

# OAuth (optional) — bỏ trống = ẩn nút social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
